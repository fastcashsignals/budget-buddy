<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Budget Buddy — Buck</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <div id="app">
        <!-- SPLASH / WELCOME -->
        <section id="scene-welcome" class="scene active">
            <div class="pet-container">
                <div class="pet buck" id="buck">
                    <div class="buck-body">
                        <div class="buck-face">
                            <div class="eyes">
                                <div class="eye left"><div class="pupil"></div></div>
                                <div class="eye right"><div class="pupil"></div></div>
                            </div>
                            <div class="nose"></div>
                            <div class="mouth"></div>
                            <div class="cheeks">
                                <div class="cheek left"></div>
                                <div class="cheek right"></div>
                            </div>
                        </div>
                        <div class="ears">
                            <div class="ear left"></div>
                            <div class="ear right"></div>
                        </div>
                        <div class="antlers">
                            <div class="antler left">
                                <div class="antler-branch a1"></div>
                                <div class="antler-branch a2"></div>
                            </div>
                            <div class="antler right">
                                <div class="antler-branch a1"></div>
                                <div class="antler-branch a2"></div>
                            </div>
                        </div>
                        <div class="sparkles">
                            <span></span><span></span><span></span><span></span>
                        </div>
                    </div>
                    <div class="shadow"></div>
                </div>
            </div>
            <h1>Hey, I'm Buck!</h1>
            <p class="sub">Your budget buddy who keeps it real.<br>Let's build your money plan together.</p>
            <button class="btn-primary" onclick="goto('income')" id="btn-start">Let's Go! 🚀</button>
        </section>

        <!-- INCOME WIZARD -->
        <section id="scene-income" class="scene">
            <div class="pet-mini" id="buck-mini">
                <div class="buck-body mini">
                    <div class="buck-face">
                        <div class="eyes"><div class="eye"><div class="pupil"></div></div><div class="eye"><div class="pupil"></div></div></div>
                        <div class="nose"></div>
                        <div class="mouth"></div>
                    </div>
                </div>
            </div>

            <div class="chat-bubble" id="income-bubble">
                First things first — how much money did you make this month?
            </div>

            <div class="form-card">
                <label>Your monthly income</label>
                <div class="money-input">
                    <span class="dollar">$</span>
                    <input type="number" id="total-income" placeholder="0.00" min="0" step="0.01">
                </div>

                <div class="income-breakdown" id="income-breakdown">
                    <p class="help-text">Where's it coming from? (pick all that apply)</p>
                    <div class="chip-grid">
                        <button class="chip" data-type="job" onclick="toggleChip(this)">💼 Day job</button>
                        <button class="chip" data-type="side" onclick="toggleChip(this)">🚀 Side hustle</button>
                        <button class="chip" data-type="freelance" onclick="toggleChip(this)">💻 Freelance</button>
                        <button class="chip" data-type="investment" onclick="toggleChip(this)">📈 Investments</button>
                        <button class="chip" data-type="rental" onclick="toggleChip(this)">🏠 Rental income</button>
                        <button class="chip" data-type="other" onclick="toggleChip(this)">✨ Other</button>
                    </div>
                </div>

                <button class="btn-primary" onclick="saveIncome()" id="btn-income-next">Next Step →</button>
            </div>
        </section>

        <!-- EXPENSES WIZARD -->
        <section id="scene-expenses" class="scene">
            <div class="pet-mini"><div class="buck-body mini"><div class="buck-face"><div class="eyes"><div class="eye"><div class="pupil"></div></div><div class="eye"><div class="pupil"></div></div></div><div class="nose"></div><div class="mouth"></div></div></div></div>
            <div class="chat-bubble" id="expense-bubble">
                Time to track where your money goes. Don't worry, no judgment here!
            </div>

            <div class="expense-categories" id="expense-categories">
                <!-- Populated by JS -->
            </div>

            <div class="expense-detail-form hidden" id="expense-detail-form">
                <div class="form-card">
                    <h3 id="expense-category-title">Category</h3>
                    <div id="expense-items-container"></div>
                    <button class="btn-add-item" onclick="addExpenseItem()">+ Add another</button>
                    <div class="form-actions">
                        <button class="btn-secondary" onclick="closeExpenseForm()">Done</button>
                    </div>
                </div>
            </div>

            <div class="wizard-nav" id="wizard-nav">
                <button class="btn-primary" onclick="goto('dashboard')" id="btn-finish-expenses">
                    See My Results 🎯
                </button>
            </div>
        </section>

        <!-- DASHBOARD -->
        <section id="scene-dashboard" class="scene">
            <header class="dash-header">
                <div class="header-left">
                    <div class="pet-tiny"><div class="buck-body tiny"><div class="buck-face"><div class="eyes"><div class="eye"><div class="pupil"></div></div><div class="eye"><div class="pupil"></div></div></div><div class="nose"></div></div></div></div>
                    <div>
                        <h2>Budget Buddy</h2>
                        <p class="month-label" id="month-label">June 2026</p>
                    </div>
                </div>
                <div class="header-actions">
                    <button class="icon-btn" onclick="editBudget()" title="Edit budget">✏️</button>
                    <button class="icon-btn" onclick="resetBudget()" title="Start over">🔄</button>
                </div>
            </header>

            <div class="dashboard-grid">
                <!-- Status Card -->
                <div class="card status-card" id="status-card">
                    <div class="pet-status" id="pet-status">
                        <div class="buck-body" id="buck-status">
                            <div class="buck-face">
                                <div class="eyes"><div class="eye"><div class="pupil"></div></div><div class="eye"><div class="pupil"></div></div></div>
                                <div class="nose"></div>
                                <div class="mouth" id="buck-mouth"></div>
                            </div>
                            <div class="ears"><div class="ear left"></div><div class="ear right"></div></div>
                            <div class="antlers"><div class="antler left"><div class="antler-branch a1"></div><div class="antler-branch a2"></div></div><div class="antler right"><div class="antler-branch a1"></div><div class="antler-branch a2"></div></div></div>
                        </div>
                        <div class="hunger-bar-container">
                            <div class="hunger-label">Buck's Health</div>
                            <div class="hunger-bar"><div class="hunger-fill" id="hunger-fill"></div></div>
                        </div>
                    </div>
                    <div class="status-text" id="status-text">
                        <h3 id="status-headline">Loading...</h3>
                        <p id="status-message">...</p>
                    </div>
                </div>

                <!-- Big Numbers -->
                <div class="card numbers-card">
                    <div class="number-row">
                        <div class="number-item income">
                            <span class="number-label">Income</span>
                            <span class="number-value" id="dash-income">$0</span>
                        </div>
                        <div class="number-item spent">
                            <span class="number-label">Spent</span>
                            <span class="number-value" id="dash-spent">$0</span>
                        </div>
                        <div class="number-item left" id="left-container">
                            <span class="number-label">Left Over</span>
                            <span class="number-value" id="dash-left">$0</span>
                        </div>
                    </div>
                </div>

                <!-- Breakdown -->
                <div class="card breakdown-card">
                    <h3>Where Your Money Went</h3>
                    <div class="breakdown-list" id="breakdown-list"></div>
                </div>

                <!-- Water Status -->
                <div class="card water-card" id="water-card">
                    <div class="water-icon">🌊</div>
                    <h3>Underwater Check</h3>
                    <p id="water-text">Loading...</p>
                    <div class="water-depth" id="water-depth">
                        <div class="water-fill" id="water-fill"></div>
                        <div class="safe-zone">Safe Zone</div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <script src="app.js"></script>
</body>
</html>
